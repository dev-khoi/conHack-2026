## Backend environment variables (example)
## Copy to backend/.env and fill values.

# FastAPI / CORS
BACKEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=aura

# Auth0 JWT verification
# Use your tenant domain (without protocol), e.g. "dev-abc123.us.auth0.com"
AUTH0_DOMAIN=
# Must match the audience requested by the frontend
AUTH0_AUDIENCE=

# OpenRouter (LLM + embeddings)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Chroma (optional)
# Cloud (recommended):
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
# Local persistent alternative:
CHROMA_PERSIST_DIR=
CHROMA_SKILLS_COLLECTION=skills
CHROMA_MEMORY_CHUNKS_COLLECTION=memory_chunks
CHROMA_MEMORY_SUMMARIES_COLLECTION=memory_summaries

# Image generation (optional)
STABILITY_API_KEY=

# S3 screenshots
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
# Optional override for custom domain/CDN, e.g. https://cdn.example.com
S3_PUBLIC_BASE_URL=
